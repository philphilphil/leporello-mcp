{
  "name": "leporello-mcp",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "npm run build --prefix web && SERVICE_NAME=web tsx --env-file=.env src/index.ts",
    "dev:fresh": "npm run scrape && npm run dev",
    "scrape": "SERVICE_NAME=scraper tsx --env-file=.env src/scrape.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "better-sqlite3": "^12.0.0",
    "cheerio": "^1.0.0",
    "node-cron": "^4.0.0",
    "playwright": "^1.59.1",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^25.0.0",
    "@types/node-cron": "^3.0.11",
    "tsx": "^4.19.0",
    "typescript": "^6.0.0",
    "vitest": "^4.0.0"
  }
}
