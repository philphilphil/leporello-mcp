---
// EventList is a pure shell — filter.ts populates #event-list at runtime.
---

<section class="events-section">
  <div class="events-header">
    <span id="event-count" class="events-count"></span>
  </div>

  <div id="event-list" class="event-list">
    <!-- Populated by filter.ts -->
  </div>
</section>

<style is:global>
  .events-section {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 3rem 4rem;
  }

  .events-header {
    padding: 0.75rem 0 0.25rem;
  }

  .events-count {
    font-family: var(--sans);
    font-size: 0.8rem;
    font-weight: 400;
    color: var(--text-muted);
  }

  /* ── Table ── */
  .event-table {
    width: 100%;
    border-collapse: collapse;
    table-layout: fixed;
  }

  /* ── Date header row ── */
  .date-row td {
    padding: 0;
  }

  .date-header {
    font-family: var(--serif);
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--accent);
    padding: 1.25rem 0 0.3rem !important;
    letter-spacing: 0.01em;
    line-height: 1.2;
  }

  .date-row:first-child .date-header {
    padding-top: 0.5rem !important;
  }

  /* ── Event rows ── */
  .event-row td {
    padding: 0.5rem 0.75rem 0.5rem 0;
    border-bottom: 1px solid var(--border-light);
    vertical-align: baseline;
  }

  .event-row td:last-child {
    padding-right: 0;
  }

  .event-row:hover td {
    background: var(--accent-faint);
  }

  /* ── Columns ── */
  .event-time {
    font-family: var(--sans);
    font-size: 0.9rem;
    font-weight: 400;
    color: var(--text-muted);
    width: 4rem;
    font-variant-numeric: tabular-nums;
    white-space: nowrap;
  }

  .event-title {
    font-family: var(--serif);
    font-size: 1.15rem;
    font-weight: 500;
    color: var(--text);
    line-height: 1.35;
  }

  .event-link {
    color: var(--text);
    text-decoration: none;
    transition: color 0.1s ease;
  }

  .event-link:hover {
    color: var(--accent);
  }

  .event-venue {
    font-family: var(--sans);
    font-size: 0.85rem;
    color: var(--text-mid);
    font-weight: 400;
    width: 15rem;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .event-location {
    color: var(--text-muted);
    font-weight: 300;
  }

  .event-people {
    font-family: var(--sans);
    font-size: 0.82rem;
    color: var(--text-muted);
    font-weight: 400;
    width: 16rem;
    text-align: right;
    line-height: 1.4;
  }

  .people-label {
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--text-muted);
    opacity: 0.6;
    margin-right: 0.25em;
  }

  /* ── No results ── */
  .no-results {
    font-family: var(--serif);
    font-size: 1.1rem;
    font-weight: 400;
    font-style: italic;
    color: var(--text-muted);
    padding: 3rem 0;
    text-align: center;
  }

  /* ── Mobile ── */
  @media (max-width: 900px) {
    .event-people {
      display: none;
    }
  }

  @media (max-width: 700px) {
    .events-section {
      padding: 0 1.5rem 3rem;
    }

    .event-table {
      table-layout: auto;
    }

    .event-time {
      width: auto;
      font-size: 0.85rem;
    }

    .event-title {
      font-size: 1.05rem;
    }

    .event-venue {
      width: auto;
      font-size: 0.8rem;
    }
  }
</style>
