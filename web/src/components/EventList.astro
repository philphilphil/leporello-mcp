---
// EventList is a pure shell — filter.ts populates #event-list at runtime.
---

<section class="events-section">
  <div class="events-header">
    <span id="event-count" class="events-count"></span>
  </div>

  <div id="event-list" class="event-list">
    <!-- Populated by filter.ts -->
  </div>
</section>

<style is:global>
  .events-section {
    max-width: 1080px;
    margin: 0 auto;
    padding: 0 2.5rem 5rem;
  }

  .events-header {
    padding: 1rem 0 0.5rem;
  }

  .events-count {
    font-family: var(--sans);
    font-size: 0.85rem;
    font-weight: 400;
    color: var(--text-muted);
  }

  /* ── Date groups ── */
  .date-group {
    margin-bottom: 0;
  }

  .date-header {
    font-family: var(--serif);
    font-size: 1.35rem;
    font-weight: 500;
    color: var(--accent);
    padding: 1.75rem 0 0.4rem;
    letter-spacing: 0.01em;
    line-height: 1.2;
  }

  .date-group:first-child .date-header {
    padding-top: 0.75rem;
  }

  /* ── Event rows ── */
  .event-row {
    display: flex;
    align-items: baseline;
    gap: 1.5rem;
    padding: 0.75rem 0.75rem;
    margin: 0 -0.75rem;
    border-radius: 6px;
    text-decoration: none;
    color: var(--text);
    transition: background 0.1s ease;
    border-bottom: 1px solid var(--border-light);
  }

  .event-row:last-child {
    border-bottom: none;
  }

  a.event-row {
    cursor: pointer;
  }

  a.event-row:hover {
    background: var(--accent-faint);
    border-bottom-color: transparent;
  }

  a.event-row:hover .event-title {
    color: var(--accent);
  }

  /* ── Time ── */
  .event-time {
    font-family: var(--sans);
    font-size: 0.95rem;
    font-weight: 400;
    color: var(--text-muted);
    min-width: 48px;
    flex-shrink: 0;
    font-variant-numeric: tabular-nums;
  }

  /* ── Info block ── */
  .event-info {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    min-width: 0;
    flex: 1;
  }

  .event-title {
    font-family: var(--serif);
    font-size: 1.3rem;
    font-weight: 500;
    color: var(--text);
    line-height: 1.3;
    transition: color 0.1s ease;
  }

  .event-details {
    font-family: var(--sans);
    font-size: 0.9rem;
    color: var(--text-mid);
    font-weight: 400;
  }

  /* ── No results ── */
  .no-results {
    font-family: var(--serif);
    font-size: 1.2rem;
    font-weight: 400;
    font-style: italic;
    color: var(--text-muted);
    padding: 4rem 0;
    text-align: center;
  }

  /* ── Mobile ── */
  @media (max-width: 700px) {
    .events-section {
      padding: 0 1.5rem 3rem;
    }

    .event-row {
      gap: 1rem;
      padding: 0.65rem 0.5rem;
      margin: 0 -0.5rem;
    }

    .event-time {
      min-width: 42px;
      font-size: 0.9rem;
    }

    .event-title {
      font-size: 1.15rem;
    }

    .event-details {
      font-size: 0.85rem;
    }
  }
</style>
