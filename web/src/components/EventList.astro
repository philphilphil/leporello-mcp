---
// EventList is a pure shell — filter.ts populates #event-list at runtime.
---

<section class="events-section">
  <div class="events-header">
    <span id="event-count" class="events-count"></span>
  </div>

  <div id="event-list" class="event-list">
    <!-- Populated by filter.ts -->
  </div>
</section>

<style is:global>
  /* ── Section shell ── */
  .events-section {
    max-width: 960px;
    margin: 0 auto;
    padding: 0 2rem 5rem;
  }

  .events-header {
    padding: 1.25rem 0;
  }

  .events-count {
    font-family: var(--sans);
    font-size: 0.8rem;
    font-weight: 400;
    color: var(--text-muted);
  }

  /* ── Date groups ── */
  .date-group {
    margin-bottom: 0.5rem;
  }

  .date-header {
    font-family: var(--serif);
    font-size: 1.15rem;
    font-weight: 500;
    color: var(--accent);
    padding: 1.5rem 0 0.5rem;
    letter-spacing: 0.01em;
    line-height: 1.2;
  }

  /* ── Event rows ── */
  .event-row {
    display: flex;
    align-items: baseline;
    gap: 1.25rem;
    padding: 0.7rem 0.5rem;
    margin: 0 -0.5rem;
    border-radius: 4px;
    text-decoration: none;
    color: var(--text);
    transition: background 0.12s ease;
  }

  a.event-row {
    cursor: pointer;
  }

  a.event-row:hover {
    background: var(--accent-faint);
  }

  a.event-row:hover .event-title {
    color: var(--accent);
  }

  /* ── Time ── */
  .event-time {
    font-family: var(--sans);
    font-size: 0.85rem;
    font-weight: 400;
    color: var(--text-muted);
    min-width: 44px;
    flex-shrink: 0;
    font-variant-numeric: tabular-nums;
  }

  /* ── Info block ── */
  .event-info {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
    min-width: 0;
    flex: 1;
  }

  .event-title {
    font-family: var(--serif);
    font-size: 1.15rem;
    font-weight: 500;
    color: var(--text);
    line-height: 1.3;
    transition: color 0.12s ease;
  }

  .event-details {
    font-family: var(--sans);
    font-size: 0.8rem;
    color: var(--text-mid);
    font-weight: 400;
    letter-spacing: 0.005em;
  }

  /* ── No results ── */
  .no-results {
    font-family: var(--serif);
    font-size: 1.1rem;
    font-weight: 400;
    font-style: italic;
    color: var(--text-muted);
    padding: 4rem 0;
    text-align: center;
  }

  /* ── Mobile ── */
  @media (max-width: 700px) {
    .events-section {
      padding: 0 1.25rem 3rem;
    }

    .event-row {
      gap: 0.75rem;
      padding: 0.6rem 0.4rem;
      margin: 0 -0.4rem;
    }

    .event-time {
      min-width: 38px;
      font-size: 0.8rem;
    }

    .event-title {
      font-size: 1.05rem;
    }
  }
</style>
