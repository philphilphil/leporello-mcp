---
// EventList is a pure shell — filter.ts populates #event-list at runtime.
// This component provides the structural wrapper and count display.
---

<section class="events-section">
  <div class="events-header">
    <span class="events-count-label">Showing</span>
    <span id="event-count" class="events-count">— events</span>
  </div>

  <div id="event-list" class="event-list">
    <!-- Populated by filter.ts -->
  </div>
</section>

<style is:global>
  /* ── Section shell ── */
  .events-section {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 2rem 4rem;
  }

  .events-header {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
    padding: 1.5rem 0 1rem;
    border-bottom: 1px solid var(--border);
    margin-bottom: 0;
  }

  .events-count-label {
    font-family: var(--serif);
    font-size: 0.7rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--text-faint);
  }

  .events-count {
    font-family: var(--serif);
    font-size: 0.85rem;
    color: var(--text-muted);
    font-style: italic;
  }

  /* ── Date groups ── */
  .date-group {
    margin-top: 0;
  }

  .date-header {
    font-family: var(--serif);
    font-size: 0.72rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--gold);
    font-weight: 500;
    font-style: normal;
    padding: 1.5rem 0 0.6rem;
    border-bottom: 1px solid var(--border);
    margin-bottom: 0;
  }

  /* ── Event rows ── */
  .event-row {
    display: flex;
    align-items: baseline;
    gap: 1.25rem;
    padding: 0.85rem 0;
    border-bottom: 1px solid var(--border);
    transition: background 0.15s;
    text-decoration: none;
    color: var(--text);
    position: relative;
  }

  a.event-row {
    cursor: pointer;
  }

  a.event-row::after {
    content: '';
    position: absolute;
    inset: 0;
    background: var(--gold);
    opacity: 0;
    transition: opacity 0.15s;
    pointer-events: none;
  }

  a.event-row:hover {
    color: var(--text);
  }

  a.event-row:hover::after {
    opacity: 0.04;
  }

  a.event-row:hover .event-title {
    color: var(--gold-bright);
  }

  /* ── Time ── */
  .event-time {
    font-family: var(--serif);
    font-size: 0.8rem;
    color: var(--text-faint);
    min-width: 48px;
    flex-shrink: 0;
    font-variant-numeric: tabular-nums;
    letter-spacing: 0.03em;
    padding-top: 0.1rem;
    font-style: italic;
  }

  /* ── Info block ── */
  .event-info {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    min-width: 0;
    flex: 1;
  }

  .event-title {
    font-family: var(--serif);
    font-size: 1.05rem;
    font-weight: 400;
    color: var(--text);
    line-height: 1.35;
    transition: color 0.15s;
    /* Prevent overflow on long opera titles */
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .event-details {
    font-family: var(--sans);
    font-size: 0.78rem;
    color: var(--text-muted);
    font-weight: 300;
    letter-spacing: 0.01em;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  /* ── No results ── */
  .no-results {
    font-family: var(--serif);
    font-size: 1rem;
    font-style: italic;
    color: var(--text-faint);
    padding: 3rem 0;
    text-align: center;
  }

  /* ── Mobile ── */
  @media (max-width: 700px) {
    .events-section {
      padding: 0 1.25rem 3rem;
    }

    .event-row {
      gap: 0.85rem;
    }

    .event-time {
      min-width: 40px;
    }

    .event-title {
      font-size: 0.97rem;
    }
  }
</style>
