---
interface City {
  id: string;
  name: string;
  country: string;
  venue_count: number;
}

interface Props {
  cities: City[];
}

const { cities } = Astro.props;
const countryCodes = [...new Set(cities.map(c => c.country))].sort();
const countryNames = new Intl.DisplayNames(['en'], { type: 'region' });
const countries = countryCodes.map(code => ({ code, name: countryNames.of(code) ?? code }));
---

<aside class="filters-panel">
  <div class="filters-inner">
    <div class="filters-bar">
      <div class="filter-group filter-group--search">
        <label class="filter-label" for="filter-search" data-i18n="filter.search">Search</label>
        <div class="input-wrapper">
          <svg class="search-icon" width="16" height="16" viewBox="0 0 16 16" fill="none"><circle cx="7" cy="7" r="5.5" stroke="currentColor" stroke-width="1.4"/><line x1="11" y1="11" x2="15" y2="15" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/></svg>
          <input
            id="filter-search"
            class="filter-input"
            type="text"
            placeholder="Search events..."
            data-i18n-placeholder="filter.search.placeholder"
            autocomplete="off"
            spellcheck="false"
          />
        </div>
      </div>
      <details id="filter-details" class="filter-details" open>
        <summary id="filter-toggle" class="filter-toggle" data-i18n="filter.toggle">Filters</summary>
        <div class="filter-details-body">
          <div class="filter-group">
            <label class="filter-label" for="filter-country" data-i18n="filter.country">Country</label>
            <div class="select-wrapper">
              <select id="filter-country" class="filter-select">
                <option value="" data-i18n="filter.all_countries">All Countries</option>
                {countries.map(c => (
                  <option value={c.code}>{c.name}</option>
                ))}
              </select>
              <svg class="select-chevron" width="12" height="7" viewBox="0 0 12 7" fill="none"><path d="M1 1l5 5 5-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </div>
          </div>

          <div class="filter-group">
            <label class="filter-label" for="filter-city" data-i18n="filter.city">City</label>
            <div class="select-wrapper">
              <select id="filter-city" class="filter-select">
                <option value="" data-i18n="filter.all_cities">All Cities</option>
                {cities.map(city => (
                  <option value={city.id}>{city.name}</option>
                ))}
              </select>
              <svg class="select-chevron" width="12" height="7" viewBox="0 0 12 7" fill="none"><path d="M1 1l5 5 5-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </div>
          </div>

          <div class="filter-group">
            <label class="filter-label" for="filter-venue" data-i18n="filter.venue">Venue</label>
            <div class="select-wrapper">
              <select id="filter-venue" class="filter-select">
                <option value="" data-i18n="filter.all_venues">All Venues</option>
              </select>
              <svg class="select-chevron" width="12" height="7" viewBox="0 0 12 7" fill="none"><path d="M1 1l5 5 5-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </div>
          </div>

          <div class="filter-group">
            <label class="filter-label" for="filter-days" data-i18n="filter.period">Period</label>
            <div class="select-wrapper">
              <select id="filter-days" class="filter-select">
                <option value="7" data-i18n="filter.next_days" data-i18n-vars='{"n":"7"}'>Next 7 days</option>
                <option value="14" data-i18n="filter.next_days" data-i18n-vars='{"n":"14"}'>Next 14 days</option>
                <option value="30" selected data-i18n="filter.next_days" data-i18n-vars='{"n":"30"}'>Next 30 days</option>
                <option value="90" data-i18n="filter.next_days" data-i18n-vars='{"n":"90"}'>Next 90 days</option>
              </select>
              <svg class="select-chevron" width="12" height="7" viewBox="0 0 12 7" fill="none"><path d="M1 1l5 5 5-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </div>
          </div>

          <button id="filter-clear" class="filter-clear" type="button" title="Clear all filters" aria-label="Clear all filters" data-i18n-title="filter.clear" data-i18n-aria-label="filter.clear">
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M1 1l12 12M13 1L1 13" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/></svg>
            <span data-i18n="filter.clear">Clear all</span>
          </button>
        </div>
      </details>
    </div>
  </div>
</aside>

<style>
  .filters-panel {
    background: var(--bg-card);
    border-bottom: 1px solid var(--border);
    position: sticky;
    top: 0;
    z-index: 10;
    box-shadow: 0 1px 4px rgba(0,0,0,0.06);
  }

  .filters-inner {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 3rem;
  }

  .filters-bar {
    display: flex;
    align-items: stretch;
  }

  /* --- Details / Summary (toggle) --- */
  .filter-details {
    display: contents;
    order: 0;
  }

  .filter-toggle {
    display: none;
  }

  .filter-details-body {
    display: contents;
  }

  .filter-details-body .filter-group:first-child {
    padding-left: 0;
  }

  /* --- Filter groups --- */
  .filter-group {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 0.35rem;
    padding: 1.15rem 2rem;
    border-right: 1px solid var(--border-light);
    min-width: 0;
  }

  .filter-group:last-child {
    border-right: none;
  }

  .filter-group--search {
    order: 1;
    flex: 1;
    border-right: none;
    padding-right: 0;
    padding-left: 2rem;
  }

  .filter-label {
    font-family: var(--sans);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-muted);
    user-select: none;
  }

  .select-wrapper {
    position: relative;
    display: flex;
    align-items: center;
  }

  .filter-select {
    appearance: none;
    -webkit-appearance: none;
    background: transparent;
    border: none;
    color: var(--text);
    font-family: var(--sans);
    font-size: 1rem;
    font-weight: 400;
    padding: 0.25rem 2rem 0.25rem 0;
    cursor: pointer;
    outline: none;
    width: 100%;
    min-width: 140px;
    line-height: 1.4;
  }

  .filter-select:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
    border-radius: 2px;
  }

  .filter-select option {
    background: var(--bg-card);
    color: var(--text);
    font-size: 1rem;
  }

  .select-chevron {
    position: absolute;
    right: 0.4rem;
    color: var(--text-muted);
    pointer-events: none;
  }

  .input-wrapper {
    width: 100%;
    position: relative;
    display: flex;
    align-items: center;
  }

  .search-icon {
    position: absolute;
    left: 0;
    color: var(--text-muted);
    pointer-events: none;
  }

  .filter-input {
    background: transparent;
    border: none;
    color: var(--text);
    font-family: var(--sans);
    font-size: 1rem;
    font-weight: 400;
    padding: 0.25rem 0 0.25rem 1.8rem;
    outline: none;
    width: 100%;
    line-height: 1.4;
  }

  .filter-input:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
    border-radius: 2px;
  }

  .filter-input::placeholder {
    color: var(--text-muted);
    font-weight: 300;
  }

  /* --- Clear button --- */
  .filter-clear {
    display: none;
    align-items: center;
    justify-content: center;
    gap: 0.4rem;
    background: none;
    border: none;
    color: var(--text-muted);
    cursor: pointer;
    padding: 0.25rem;
    flex-shrink: 0;
    transition: color 0.15s;
    font-family: var(--sans);
    font-size: 0.85rem;
  }

  .filter-clear:hover {
    color: var(--text);
  }

  .filter-clear.visible {
    display: flex;
  }

  /* --- Desktop: details forced open, summary hidden --- */
  @media (min-width: 701px) {
    .filter-clear {
      padding: 1.15rem 2rem;
    }

    .filter-clear span {
      display: none;
    }
  }

  /* --- Mobile --- */
  @media (max-width: 700px) {
    .filters-inner {
      padding: 0 1.5rem;
    }

    .filters-bar {
      flex-wrap: wrap;
      align-items: center;
    }

    /* Search takes most of the row */
    .filter-group--search {
      order: 0;
      flex: 1;
      border-right: none;
      border-bottom: none;
      padding: 0.9rem 0;
      padding-left: 0;
      min-width: 0;
    }

    /* Details element becomes a block, not display:contents */
    .filter-details {
      display: block;
      flex-shrink: 0;
    }

    /* Summary becomes the toggle button */
    .filter-toggle {
      display: flex;
      align-items: center;
      font-family: var(--sans);
      font-size: 0.85rem;
      font-weight: 500;
      color: var(--text-muted);
      background: none;
      border: 1px solid var(--border-light);
      border-radius: 6px;
      padding: 0.5rem 0.85rem;
      cursor: pointer;
      user-select: none;
      list-style: none;
      white-space: nowrap;
    }

    .filter-toggle::-webkit-details-marker {
      display: none;
    }

    .filter-toggle::marker {
      content: '';
    }

    /* Body is a dropdown panel below the bar */
    .filter-details-body {
      display: none;
      flex-direction: column;
      width: 100vw;
      margin-left: -1.5rem;
      padding: 0 1.5rem;
      background: var(--bg-card);
      border-top: 1px solid var(--border-light);
    }

    .filter-details[open] .filter-details-body {
      display: flex;
    }

    .filter-details-body .filter-group {
      border-right: none;
      border-bottom: 1px solid var(--border-light);
      padding: 0.9rem 0;
      width: 100%;
    }

    .filter-details-body .filter-group:last-child {
      border-bottom: none;
    }

    .filter-select {
      min-width: unset;
      width: 100%;
    }

    .filter-clear {
      padding: 0.9rem 0;
      justify-content: flex-end;
    }

    .filter-clear span {
      display: inline;
    }
  }
</style>
