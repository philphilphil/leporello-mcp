---
interface City {
  id: string;
  name: string;
  country: string;
  venue_count: number;
}

interface Props {
  cities: City[];
}

const { cities } = Astro.props;
const countryCodes = [...new Set(cities.map(c => c.country))].sort();
const countryNames = new Intl.DisplayNames(['en'], { type: 'region' });
const countries = countryCodes.map(code => ({ code, name: countryNames.of(code) ?? code }));

const periods = [7, 14, 30, 90];
const chevron = '<path d="M6 9 L12 15 L18 9"/>';
---

<section class="filters" aria-label="Filters">
  <label class="search">
    <svg class="search-icon" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="11" cy="11" r="7"/><path d="M20 20 L16 16"/></svg>
    <input
      id="filter-search"
      class="filter-input"
      type="search"
      placeholder="Search works, venues, performers…"
      data-i18n-placeholder="filter.search.placeholder"
      aria-label="Search"
      data-i18n-aria-label="filter.search"
      autocomplete="off"
      spellcheck="false"
    />
  </label>

  <div class="control">
    <select id="filter-country" class="filter-select" aria-label="Country" data-i18n-aria-label="filter.country">
      <option value="" data-i18n="filter.all_countries">All Countries</option>
      {countries.map(c => (<option value={c.code}>{c.name}</option>))}
    </select>
    <svg class="chev" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" set:html={chevron} />
  </div>

  <button
    id="filter-locate"
    class="locate-btn"
    type="button"
    aria-label="Use my location"
    title="Use my location"
    data-i18n-aria-label="filter.locate"
    data-i18n-title="filter.locate"
  >
    <svg class="icon-pin" aria-hidden="true" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 21s-6-5.3-6-10a6 6 0 0 1 12 0c0 4.7-6 10-6 10Z"/><circle cx="12" cy="11" r="2.2"/></svg>
    <svg class="icon-spin" aria-hidden="true" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round"><path d="M12 3 a9 9 0 0 1 9 9" /></svg>
  </button>

  <div class="control">
    <select id="filter-city" class="filter-select" aria-label="City" data-i18n-aria-label="filter.city">
      <option value="" data-i18n="filter.all_cities">All Cities</option>
      {cities.map(city => (<option value={city.id}>{city.name}</option>))}
    </select>
    <svg class="chev" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" set:html={chevron} />
  </div>

  <div class="control">
    <select id="filter-venue" class="filter-select" aria-label="Venue" data-i18n-aria-label="filter.venue">
      <option value="" data-i18n="filter.all_venues">All Venues</option>
    </select>
    <svg class="chev" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" set:html={chevron} />
  </div>

  <div class="period-group">
    <div class="seg" id="filter-days" role="group" aria-label="Period" data-i18n-aria-label="filter.period">
      {periods.map(n => (
        <button
          type="button"
          class:list={['seg-btn', { 'is-active': n === 30 }]}
          data-days={String(n)}
          aria-pressed={n === 30 ? 'true' : 'false'}
          aria-label={`Next ${n} days`}
          data-i18n-aria-label="filter.next_days"
          data-i18n-vars={JSON.stringify({ n: String(n) })}
        >
          <span data-i18n="filter.days_short" data-i18n-vars={JSON.stringify({ n: String(n) })}>{n}d</span>
        </button>
      ))}
    </div>

    <button id="filter-clear" class="clear-btn" type="button" aria-label="Clear all filters" title="Clear all filters" data-i18n-aria-label="filter.clear" data-i18n-title="filter.clear">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"><path d="M5 5 L19 19 M19 5 L5 19"/></svg>
    </button>
  </div>

  <p id="filter-locate-status" class="locate-status" role="status" aria-live="polite"></p>
</section>

<style>
  .filters {
    margin-top: 24px;
    display: flex;
    align-items: center;
    gap: 12px;
    flex-wrap: wrap;
  }

  .search {
    flex: 1 1 220px;
    min-width: 0;
    position: relative;
    display: flex;
    align-items: center;
  }

  /* Segmented period + clear travel together so the clear never wraps alone */
  .period-group {
    display: flex;
    align-items: center;
    gap: 12px;
    flex: none;
  }
  .search-icon {
    position: absolute;
    left: 16px;
    color: var(--text-muted);
    pointer-events: none;
  }
  .filter-input {
    width: 100%;
    font: inherit;
    font-size: 15px;
    color: var(--text);
    background: var(--surface);
    border: 0;
    border-radius: var(--pill);
    padding: 12px 18px 12px 44px;
    box-shadow: var(--shadow-sm);
    outline: none;
    transition: box-shadow 0.15s ease;
  }
  .filter-input::placeholder { color: var(--text-muted); }
  .filter-input:focus-visible {
    box-shadow: 0 0 0 2px var(--accent), var(--shadow-sm);
    outline: none;
  }
  /* hide the native search clear control for a cleaner look */
  .filter-input::-webkit-search-cancel-button { -webkit-appearance: none; }

  .control { position: relative; flex: none; }
  .filter-select {
    appearance: none;
    -webkit-appearance: none;
    font: inherit;
    font-size: 14px;
    font-weight: 500;
    color: var(--text);
    background: var(--surface);
    border: 0;
    border-radius: var(--pill);
    padding: 11px 38px 11px 18px;
    box-shadow: var(--shadow-sm);
    cursor: pointer;
    outline: none;
    max-width: 220px;
    text-overflow: ellipsis;
    transition: box-shadow 0.15s ease;
  }
  .filter-select:focus-visible {
    box-shadow: 0 0 0 2px var(--accent), var(--shadow-sm);
    outline: none;
  }
  .chev {
    position: absolute;
    right: 14px;
    top: 50%;
    transform: translateY(-50%);
    color: var(--text-muted);
    pointer-events: none;
  }

  /* Segmented period control */
  .seg {
    display: inline-flex;
    align-items: center;
    background: var(--surface-2);
    border-radius: var(--pill);
    padding: 3px;
    flex: none;
  }
  .seg-btn {
    appearance: none;
    border: 0;
    background: transparent;
    font: inherit;
    font-size: 13.5px;
    font-weight: 500;
    color: var(--text-muted);
    padding: 8px 13px;
    border-radius: var(--pill);
    cursor: pointer;
    font-variant-numeric: tabular-nums;
    transition: color 0.15s ease;
  }
  .seg-btn.is-active {
    background: var(--surface);
    color: var(--accent-text);
    box-shadow: var(--shadow-sm);
  }
  .seg-btn:not(.is-active):hover { color: var(--text-mid); }
  .seg-btn:focus-visible { outline: 2px solid var(--accent); outline-offset: 2px; }

  .clear-btn {
    display: none;
    width: 38px;
    height: 38px;
    flex: none;
    align-items: center;
    justify-content: center;
    border: 0;
    border-radius: var(--pill);
    background: var(--surface);
    color: var(--text-muted);
    cursor: pointer;
    box-shadow: var(--shadow-sm);
    transition: color 0.15s ease;
  }
  .clear-btn:hover { color: var(--accent); }
  .clear-btn.visible { display: inline-flex; }

  /* Locate (use my location) button — mirrors clear-btn, always visible */
  .locate-btn {
    width: 38px;
    height: 38px;
    flex: none;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: 0;
    border-radius: var(--pill);
    background: var(--surface);
    color: var(--text-muted);
    cursor: pointer;
    box-shadow: var(--shadow-sm);
    transition: color 0.15s ease;
  }
  .locate-btn:hover { color: var(--accent); }
  .locate-btn:focus-visible { outline: 2px solid var(--accent); outline-offset: 2px; }
  .locate-btn:disabled { cursor: default; color: var(--text-muted); }
  .locate-btn .icon-spin { display: none; }
  .locate-btn.is-busy .icon-pin { display: none; }
  .locate-btn.is-busy .icon-spin { display: block; animation: locate-spin 0.7s linear infinite; }
  @keyframes locate-spin { to { transform: rotate(360deg); } }
  @media (prefers-reduced-motion: reduce) {
    .locate-btn.is-busy .icon-spin { animation: none; }
  }

  .locate-status {
    flex: 1 1 100%;
    margin: 0;
    font-size: 13px;
    color: var(--text-muted);
  }
  .locate-status:empty { display: none; }

  @media (max-width: 560px) {
    .filters { gap: 10px; }
    .search { flex: 1 1 100%; min-width: 0; }
    .control { flex: 1 1 calc(50% - 5px); }
    .filter-select { width: 100%; max-width: none; }
    .period-group { flex: 1 1 100%; }
    .seg { flex: 1; justify-content: space-between; }
    .seg-btn { flex: 1; text-align: center; }
  }
</style>
