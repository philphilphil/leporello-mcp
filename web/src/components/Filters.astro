---
interface City {
  id: string;
  name: string;
  country: string;
  venue_count: number;
}

interface Props {
  cities: City[];
}

const { cities } = Astro.props;
---

<aside class="filters-panel">
  <div class="filters-inner">
    <div class="filter-group">
      <label class="filter-label" for="filter-city">City</label>
      <div class="select-wrapper">
        <select id="filter-city" class="filter-select">
          <option value="">All Cities</option>
          {cities.map(city => (
            <option value={city.id}>{city.name}</option>
          ))}
        </select>
        <svg class="select-chevron" width="12" height="7" viewBox="0 0 12 7" fill="none"><path d="M1 1l5 5 5-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </div>
    </div>

    <div class="filter-group">
      <label class="filter-label" for="filter-venue">Venue</label>
      <div class="select-wrapper">
        <select id="filter-venue" class="filter-select">
          <option value="">All Venues</option>
        </select>
        <svg class="select-chevron" width="12" height="7" viewBox="0 0 12 7" fill="none"><path d="M1 1l5 5 5-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </div>
    </div>

    <div class="filter-group">
      <label class="filter-label" for="filter-days">Period</label>
      <div class="select-wrapper">
        <select id="filter-days" class="filter-select">
          <option value="7">Next 7 days</option>
          <option value="14">Next 14 days</option>
          <option value="30" selected>Next 30 days</option>
          <option value="90">Next 90 days</option>
        </select>
        <svg class="select-chevron" width="12" height="7" viewBox="0 0 12 7" fill="none"><path d="M1 1l5 5 5-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </div>
    </div>

    <div class="filter-group filter-group--search">
      <label class="filter-label" for="filter-search">Search</label>
      <div class="input-wrapper">
        <svg class="search-icon" width="16" height="16" viewBox="0 0 16 16" fill="none"><circle cx="7" cy="7" r="5.5" stroke="currentColor" stroke-width="1.4"/><line x1="11" y1="11" x2="15" y2="15" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/></svg>
        <input
          id="filter-search"
          class="filter-input"
          type="text"
          placeholder="Search events..."
          autocomplete="off"
          spellcheck="false"
        />
      </div>
    </div>
  </div>
</aside>

<style>
  .filters-panel {
    background: var(--bg-card);
    border-bottom: 1px solid var(--border);
    position: sticky;
    top: 0;
    z-index: 10;
    box-shadow: 0 1px 4px rgba(0,0,0,0.06);
  }

  .filters-inner {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 3rem;
    display: flex;
    gap: 0;
    align-items: stretch;
  }

  .filter-group {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 0.35rem;
    padding: 1.15rem 2rem;
    border-right: 1px solid var(--border-light);
    min-width: 0;
  }

  .filter-group:first-child {
    padding-left: 0;
  }

  .filter-group:nth-child(2),
  .filter-group:nth-child(3) {
    padding-left: 2rem;
  }

  .filter-group:last-child {
    border-right: none;
    flex: 1;
    padding-right: 0;
  }

  .filter-group--search {
    padding-left: 2rem;
  }

  .filter-label {
    font-family: var(--sans);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-muted);
    user-select: none;
  }

  .select-wrapper {
    position: relative;
    display: flex;
    align-items: center;
  }

  .filter-select {
    appearance: none;
    -webkit-appearance: none;
    background: transparent;
    border: none;
    color: var(--text);
    font-family: var(--sans);
    font-size: 1rem;
    font-weight: 400;
    padding: 0.25rem 2rem 0.25rem 0;
    cursor: pointer;
    outline: none;
    width: 100%;
    min-width: 140px;
    line-height: 1.4;
  }

  .filter-select:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
    border-radius: 2px;
  }

  .filter-select option {
    background: var(--bg-card);
    color: var(--text);
    font-size: 1rem;
  }

  .select-chevron {
    position: absolute;
    right: 0.4rem;
    color: var(--text-muted);
    pointer-events: none;
  }

  .input-wrapper {
    width: 100%;
    position: relative;
    display: flex;
    align-items: center;
  }

  .search-icon {
    position: absolute;
    left: 0;
    color: var(--text-muted);
    pointer-events: none;
  }

  .filter-input {
    background: transparent;
    border: none;
    color: var(--text);
    font-family: var(--sans);
    font-size: 1rem;
    font-weight: 400;
    padding: 0.25rem 0 0.25rem 1.8rem;
    outline: none;
    width: 100%;
    line-height: 1.4;
  }

  .filter-input:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
    border-radius: 2px;
  }

  .filter-input::placeholder {
    color: var(--text-muted);
    font-weight: 300;
  }

  @media (max-width: 700px) {
    .filters-inner {
      flex-direction: column;
      gap: 0;
      padding: 0 1.5rem;
    }

    .filter-group {
      border-right: none;
      border-bottom: 1px solid var(--border-light);
      padding: 0.9rem 0;
      width: 100%;
    }

    .filter-group--search {
      padding-left: 0;
    }

    .filter-group:last-child {
      border-bottom: none;
    }

    .filter-select {
      min-width: unset;
      width: 100%;
    }
  }
</style>
