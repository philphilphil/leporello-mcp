---
import '@fontsource-variable/inter/wght.css';
import 'flag-icons/css/flag-icons.min.css';

import type { SupportedLang } from '../i18n/index.ts';

interface Props {
  title: string;
  lang?: SupportedLang;
  dynamicLang?: boolean;
}
const { title, lang = 'en', dynamicLang = false } = Astro.props;
---
<!DOCTYPE html>
<html lang={lang}>
<head>
  <meta charset="UTF-8" />
  <script is:inline define:vars={{ dynamicLang, lang }}>
    (function() {
      var storedLang = localStorage.getItem('lang');
      var fallbackLang = (navigator.language || '').startsWith('de') ? 'de' : 'en';
      var selectedLang = dynamicLang ? (storedLang || fallbackLang) : lang;
      var resolvedLang = selectedLang === 'de' ? 'de' : 'en';
      document.documentElement.lang = resolvedLang;
      if (!dynamicLang) {
        localStorage.setItem('lang', resolvedLang);
      }
    })();
  </script>
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="icon" type="image/x-icon" href="/favicon.ico" />
  <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
  <meta name="theme-color" content="#2f6df0" />
  <style is:global>
    *, *::before, *::after {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    :root {
      /* Surfaces */
      --bg:           #F6F7F9;   /* cool off-white page */
      --surface:      #FFFFFF;   /* raised cards */
      --surface-2:    #EEF1F5;   /* quiet fill (pills, segmented) */
      --surface-hover:#FBFCFE;   /* row hover tint */

      /* Ink scale */
      --text:         #11151C;   /* near-black slate (titles, primary) */
      --text-mid:     #4A5566;   /* secondary (venue, body) ~7:1 */
      --text-muted:   #5F6A7D;   /* tertiary (meta, cast) ~5:1 */
      --text-faint:   #98A1B0;   /* decorative only */

      /* Single accent — refined azure */
      --accent:       #2F6DF0;   /* fills, focus rings, dots */
      --accent-text:  #1C4FC4;   /* accent used AS text (links, labels) ~7:1 */
      --accent-soft:  #EAF1FE;   /* tint background */
      --accent-ring:  rgba(47, 109, 240, 0.32);

      /* Lines */
      --border:       #E2E6EC;
      --border-light: #EEF1F5;

      /* Depth */
      --shadow-sm: 0 1px 2px rgba(17,21,28,.05), 0 1px 3px rgba(17,21,28,.04);
      --shadow-md: 0 1px 2px rgba(17,21,28,.04), 0 10px 30px -12px rgba(17,21,28,.14);
      --shadow-lg: 0 1px 3px rgba(17,21,28,.05), 0 18px 48px -16px rgba(17,21,28,.18);

      /* Radii */
      --radius:    14px;
      --radius-sm: 10px;
      --radius-lg: 16px;
      --pill:      999px;

      --maxw: 1180px;

      --sans: 'Inter Variable', -apple-system, BlinkMacSystemFont, "Segoe UI", system-ui, sans-serif;
      --mono: 'SF Mono', ui-monospace, 'SFMono-Regular', 'Menlo', 'Consolas', monospace;
    }

    html {
      font-size: 16px;
      -webkit-text-size-adjust: 100%;
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
    }

    body {
      background-color: var(--bg);
      color: var(--text);
      font-family: var(--sans);
      font-weight: 400;
      min-height: 100vh;
      line-height: 1.5;
      letter-spacing: -0.011em;
      font-feature-settings: 'cv02', 'cv03', 'cv04', 'ss01';
    }

    a {
      color: inherit;
      text-decoration: none;
    }

    :focus-visible {
      outline: 2px solid var(--accent);
      outline-offset: 2px;
      border-radius: 4px;
    }

    ::selection {
      background: var(--accent);
      color: #fff;
    }

    /* Country flag chip (flag-icons span, sized by its container font-size) */
    .flag {
      border-radius: 3px;
      box-shadow: inset 0 0 0 1px rgba(17, 21, 28, 0.10);
      vertical-align: -0.16em;
      flex: none;
    }

    @media (prefers-reduced-motion: reduce) {
      *, *::before, *::after {
        transition-duration: 0.01ms !important;
        animation-duration: 0.01ms !important;
        scroll-behavior: auto !important;
      }
    }
  </style>
</head>
<body>
  <slot />
</body>
</html>
