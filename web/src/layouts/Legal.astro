---
import Base from './Base.astro';
import {
  getLegalPageHref,
  translate,
  type SupportedLang,
} from '../i18n/index.ts';

interface Props {
  title: string;
  subtitle?: string;
  date: string;
  lang: SupportedLang;
}
const { title, subtitle, date, lang } = Astro.props;
---

<Base title={`${title} — Leporello`} lang={lang}>
  <div class="legal-page">
    <header class="legal-header">
      <a href="/" class="back-link">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M10 3L5 8l5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        Leporello
      </a>
    </header>

    <main class="legal-content">
      <div class="legal-heading">
        <h1>{title}</h1>
        {subtitle && <p class="legal-subtitle">{subtitle}</p>}
        <p class="legal-date">{translate(lang, 'legal.last_updated', { date })}</p>
      </div>
      <div class="legal-body">
        <slot />
      </div>
    </main>

    <footer class="legal-footer">
      <div class="legal-footer-links">
        <a href={getLegalPageHref('terms', lang)}>{translate(lang, 'legal.terms')}</a>
        <a href={getLegalPageHref('privacy', lang)}>{translate(lang, 'legal.privacy')}</a>
        <a href={getLegalPageHref('impressum', lang)}>{translate(lang, 'legal.impressum')}</a>
      </div>
    </footer>
  </div>
</Base>

<style>
  .legal-page {
    display: flex;
    flex-direction: column;
    min-height: 100vh;
    max-width: 720px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .legal-header {
    padding: 1.5rem 0;
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--sans);
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--text-muted);
    transition: color 0.15s;
  }

  .back-link:hover {
    color: var(--accent);
  }

  .legal-content {
    flex: 1;
  }

  .legal-heading {
    margin-bottom: 2.5rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--border);
  }

  .legal-heading h1 {
    font-family: var(--serif);
    font-size: 2.2rem;
    font-weight: 400;
    color: var(--text);
    line-height: 1.2;
  }

  .legal-subtitle {
    font-family: var(--sans);
    font-size: 0.9rem;
    color: var(--text-muted);
    margin-top: 0.5rem;
  }

  .legal-date {
    font-family: var(--sans);
    font-size: 0.8rem;
    color: var(--text-muted);
    margin-top: 0.5rem;
  }

  .legal-body {
    font-family: var(--sans);
    font-size: 0.95rem;
    line-height: 1.7;
    color: var(--text);
  }

  .legal-body :global(h2) {
    font-family: var(--serif);
    font-size: 1.4rem;
    font-weight: 500;
    color: var(--text);
    margin-top: 2.5rem;
    margin-bottom: 0.75rem;
  }

  .legal-body :global(p) {
    margin-bottom: 0.75rem;
  }

  .legal-body :global(ul) {
    margin-bottom: 0.75rem;
    padding-left: 1.5rem;
  }

  .legal-body :global(li) {
    margin-bottom: 0.4rem;
  }

  .legal-body :global(a) {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .legal-body :global(a:hover) {
    color: var(--accent-light);
  }

  .legal-body :global(.address) {
    background: var(--bg-warm);
    border-radius: 6px;
    padding: 1rem 1.25rem;
    margin-bottom: 0.75rem;
    line-height: 1.6;
  }

  .legal-body :global(.address p) {
    margin-bottom: 0;
    margin-top: 0;
  }

  .legal-footer {
    margin-top: 3rem;
    padding: 1.5rem 0;
    border-top: 1px solid var(--border);
  }

  .legal-footer-links {
    display: flex;
    gap: 1.5rem;
    font-family: var(--sans);
    font-size: 0.8rem;
    color: var(--text-muted);
  }

  .legal-footer-links a {
    transition: color 0.15s;
  }

  .legal-footer-links a:hover {
    color: var(--accent);
  }

  @media (max-width: 700px) {
    .legal-page {
      padding: 0 1.5rem;
    }

    .legal-heading h1 {
      font-size: 1.8rem;
    }
  }
</style>
