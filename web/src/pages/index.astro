---
import Base from '../layouts/Base.astro';
import Filters from '../components/Filters.astro';
import EventList from '../components/EventList.astro';
import { getCities, getVenues, getEvents } from '../lib/data.ts';

const cities = getCities();
const venues = getVenues();
const events = getEvents(90);
const dataAge: Record<string, string | null> = {};
for (const v of venues) {
  if (v.last_scraped) dataAge[v.id] = v.last_scraped;
}

const pageData = { cities, venues, events, dataAge };
---

<Base title="Leporello — Opera & classical music event schedules" dynamicLang={true}>
  <script type="application/json" id="event-data" set:html={JSON.stringify(pageData)} />

  <!-- ── Sticky translucent header ── -->
  <header class="topbar">
    <div class="topbar-inner">
      <a class="brand" href="/" aria-label="Leporello — home">
        <img src="/leporello-logo.svg" alt="" class="logo-mark" width="40" height="40" />
        <span class="brand-text">
          <span class="wordmark">Leporello</span>
          <span class="tagline" data-i18n="site.tagline">Opera &amp; Classical Music Schedules</span>
        </span>
      </a>
      <div class="topbar-actions">
        <a class="topbar-link" href="/sources" data-sources-link data-i18n="footer.sources">Sources</a>
        <div class="langswitch" role="group" aria-label="Language" data-i18n-aria-label="a11y.language">
          <button type="button" class="lang-btn" data-lang="en">EN</button>
          <button type="button" class="lang-btn" data-lang="de">DE</button>
        </div>
      </div>
    </div>
  </header>

  <main class="wrap">
    <!-- ── MCP callout ── -->
    <section class="mcp" aria-label="MCP server">
      <span class="mcp-glyph" aria-hidden="true">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
          <path d="M4 7 L12 3 L20 7 L12 11 Z"/><path d="M4 7 V17 L12 21 V11"/><path d="M20 7 V17 L12 21"/>
        </svg>
      </span>
      <div class="mcp-text">
        <span class="mcp-label" data-i18n="mcp.badge">MCP Server</span>
        <p class="mcp-pitch" data-i18n="mcp.text">Connect live schedules to Claude, ChatGPT, or any MCP assistant.</p>
      </div>
      <div class="endpoint">
        <code>https://leporello.app/mcp</code>
        <button class="copy-btn" type="button" aria-label="Copy endpoint URL" title="Copy" data-i18n-aria-label="a11y.copy" data-i18n-title="a11y.copy">
          <svg class="icon-copy" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="11" height="11" rx="2.5"/><path d="M5 15 H4.5 A1.5 1.5 0 0 1 3 13.5 V4.5 A1.5 1.5 0 0 1 4.5 3 H13.5 A1.5 1.5 0 0 1 15 4.5 V5"/></svg>
          <svg class="icon-check" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:none"><path d="M4 12.5 L9 17.5 L20 6.5"/></svg>
        </button>
      </div>
    </section>

    <Filters cities={cities} />

    <EventList />
  </main>

  <footer class="site-footer">
    <div class="wrap foot-inner">
      <p class="foot-note" data-i18n="footer.note">
        Leporello aggregates publicly available concert schedules.
        All event data belongs to the respective venues.
      </p>
      <nav class="foot-nav" aria-label="Footer">
        <a href="/sources" data-sources-link data-i18n="footer.sources">Sources</a>
        <a href="/terms" data-legal-page="terms" data-i18n="legal.terms">Terms</a>
        <a href="/privacy" data-legal-page="privacy" data-i18n="legal.privacy">Privacy</a>
        <a href="/impressum" data-legal-page="impressum" data-i18n="legal.impressum">Imprint</a>
      </nav>
    </div>
    <div class="wrap">
      <p class="colophon" data-i18n="footer.colophon">Leporello &middot; a fold-out of the world&rsquo;s concert halls.</p>
    </div>
  </footer>

  <script>
    import '../scripts/filter.ts';
    import { applyTranslations, getLang, getLegalPageHref, getSourcesHref, type LegalPageSlug } from '../i18n/index.ts';

    applyTranslations();

    document.querySelectorAll<HTMLAnchorElement>('[data-legal-page]').forEach((link) => {
      const page = link.dataset.legalPage as LegalPageSlug | undefined;
      if (!page) return;
      link.href = getLegalPageHref(page, getLang());
    });

    document.querySelectorAll<HTMLAnchorElement>('[data-sources-link]').forEach((link) => {
      link.href = getSourcesHref(getLang());
    });

    // Language switcher (segmented)
    const currentLang = getLang();
    document.querySelectorAll<HTMLButtonElement>('.lang-btn').forEach((btn) => {
      const isActive = btn.dataset.lang === currentLang;
      btn.classList.toggle('is-active', isActive);
      btn.setAttribute('aria-pressed', String(isActive));
      btn.addEventListener('click', () => {
        if (btn.dataset.lang === currentLang) return;
        localStorage.setItem('lang', btn.dataset.lang!);
        location.reload();
      });
    });

    // Copy endpoint
    document.querySelector('.copy-btn')?.addEventListener('click', async (e) => {
      const btn = e.currentTarget as HTMLElement;
      const copyIcon = btn.querySelector('.icon-copy') as HTMLElement;
      const checkIcon = btn.querySelector('.icon-check') as HTMLElement;
      try {
        await navigator.clipboard.writeText('https://leporello.app/mcp');
        copyIcon.style.display = 'none';
        checkIcon.style.display = 'block';
        btn.classList.add('copied');
        setTimeout(() => {
          copyIcon.style.display = 'block';
          checkIcon.style.display = 'none';
          btn.classList.remove('copied');
        }, 1800);
      } catch { /* clipboard unavailable */ }
    });
  </script>
</Base>

<style>
  /* ── Sticky translucent header ── */
  .topbar {
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(246, 247, 249, 0.72);
    -webkit-backdrop-filter: saturate(180%) blur(18px);
    backdrop-filter: saturate(180%) blur(18px);
    border-bottom: 1px solid rgba(226, 230, 236, 0.9);
  }
  .topbar-inner {
    max-width: var(--maxw);
    margin: 0 auto;
    padding: 14px 32px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
  }
  .topbar-actions {
    display: flex;
    align-items: center;
    gap: 18px;
    flex: none;
  }
  .topbar-link {
    font-size: 14px;
    font-weight: 500;
    color: var(--text-muted);
    transition: color 0.15s ease;
  }
  .topbar-link:hover { color: var(--accent-text); }
  .brand { display: flex; align-items: center; gap: 14px; min-width: 0; }
  .logo-mark { width: 40px; height: 40px; flex: none; display: block; border-radius: 10px; }
  .brand-text { display: flex; flex-direction: column; min-width: 0; }
  .wordmark {
    font-size: 20px;
    font-weight: 600;
    letter-spacing: -0.022em;
    color: var(--text);
    line-height: 1.1;
  }
  .tagline {
    font-size: 12.5px;
    color: var(--text-muted);
    font-weight: 450;
    margin-top: 2px;
  }
  .langswitch {
    display: inline-flex;
    align-items: center;
    background: var(--surface-2);
    border-radius: var(--pill);
    padding: 3px;
    flex: none;
  }
  .lang-btn {
    appearance: none;
    border: 0;
    background: transparent;
    font: inherit;
    font-size: 13px;
    font-weight: 550;
    color: var(--text-muted);
    padding: 5px 13px;
    border-radius: var(--pill);
    cursor: pointer;
    letter-spacing: 0.01em;
    transition: color 0.15s ease;
  }
  .lang-btn.is-active {
    background: var(--surface);
    color: var(--accent-text);
    box-shadow: var(--shadow-sm);
  }
  .lang-btn:not(.is-active):hover { color: var(--text-mid); }

  .wrap { max-width: var(--maxw); margin: 0 auto; padding: 0 32px; }
  main.wrap { padding-top: 28px; }

  /* ── MCP callout ── */
  .mcp {
    background: var(--surface);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-md);
    padding: 14px 20px;
    display: flex;
    align-items: center;
    gap: 18px;
  }
  .mcp-glyph {
    width: 34px; height: 34px; flex: none;
    border-radius: 10px;
    background: var(--accent-soft);
    display: flex; align-items: center; justify-content: center;
    color: var(--accent);
  }
  .mcp-text { flex: 1 1 auto; min-width: 0; }
  .mcp-label {
    display: block;
    font-size: 11.5px;
    font-weight: 600;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    color: var(--accent-text);
  }
  .mcp-pitch {
    font-size: 14.5px;
    color: var(--text-mid);
    margin: 3px 0 0;
    font-weight: 450;
  }
  .endpoint {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background: var(--surface-2);
    border-radius: var(--pill);
    padding: 8px 8px 8px 18px;
    flex: none;
  }
  .endpoint code {
    font-family: var(--mono);
    font-size: 13.5px;
    color: var(--text);
    letter-spacing: -0.01em;
    user-select: all;
  }
  .copy-btn {
    width: 32px; height: 32px; flex: none;
    border: 0;
    border-radius: var(--pill);
    background: var(--surface);
    color: var(--text-mid);
    cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    box-shadow: var(--shadow-sm);
    transition: color 0.15s ease, transform 0.1s ease;
  }
  .copy-btn:hover { color: var(--accent); }
  .copy-btn:active { transform: scale(0.94); }
  .copy-btn.copied { color: var(--accent); }

  /* ── Footer ── */
  .site-footer {
    margin-top: 72px;
    border-top: 1px solid var(--border-light);
    padding: 48px 0 56px;
  }
  .foot-inner {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 32px 48px;
    flex-wrap: wrap;
  }
  .foot-note {
    font-size: 13.5px;
    color: var(--text-mid);
    line-height: 1.6;
    font-weight: 450;
    max-width: 420px;
  }
  .foot-nav {
    display: flex;
    flex-wrap: wrap;
    gap: 22px;
  }
  .foot-nav a {
    font-size: 13.5px;
    font-weight: 500;
    color: var(--text-muted);
    transition: color 0.15s ease;
  }
  .foot-nav a:hover { color: var(--accent-text); }
  .colophon {
    margin-top: 44px;
    font-size: 12.5px;
    color: var(--text-muted);
    font-weight: 450;
  }

  /* ── Responsive ── */
  @media (max-width: 880px) {
    .mcp { flex-wrap: wrap; gap: 16px; }
    .mcp-text { flex: 1 1 240px; }
    .endpoint { flex: 1 1 100%; justify-content: space-between; }
  }

  @media (max-width: 560px) {
    .topbar-inner { padding: 12px 18px; gap: 14px; }
    .topbar-actions { gap: 12px; }
    .wrap { padding: 0 18px; }
    main.wrap { padding-top: 20px; }
    .tagline { display: none; }
    .mcp { padding: 16px; }
    .mcp-glyph { display: none; }
    .endpoint code { font-size: 12px; }
  }
</style>
