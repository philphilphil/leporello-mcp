---
import Base from '../layouts/Base.astro';
import Filters from '../components/Filters.astro';
import EventList from '../components/EventList.astro';
import { getCities, getVenues, getEvents } from '../lib/data.ts';
import type { Venue } from '../lib/data.ts';

const cities = getCities();
const venues = getVenues();
const events = getEvents(90);
const dataAge: Record<string, string | null> = {};
for (const v of venues) {
  if (v.last_scraped) dataAge[v.id] = v.last_scraped;
}

const pageData = { cities, venues, events, dataAge };

function formatAge(iso: string | null): string {
  if (!iso) return 'never';
  const d = new Date(iso);
  return d.toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' });
}

const eventCountByVenue: Record<string, number> = {};
for (const e of events) {
  eventCountByVenue[e.venue_id] = (eventCountByVenue[e.venue_id] ?? 0) + 1;
}

const venueAgeList: Array<{ venue: Venue; age: string | null; count: number }> = venues.map(v => ({
  venue: v,
  age: dataAge[v.id] ?? null,
  count: eventCountByVenue[v.id] ?? 0,
}));
---

<Base title="Leporello — Opera & classical music event schedules">
  <script type="application/json" id="event-data" set:html={JSON.stringify(pageData)} />

  <div class="page-wrapper">
    <header class="site-header">
      <div class="header-inner">
        <div class="header-brand">
          <img src="/leporello-logo.svg" alt="" class="site-logo" />
          <div class="header-text">
            <h1 class="site-title">Leporello</h1>
            <p class="site-tagline">Opera & Classical Music Event Schedules</p>
          </div>
        </div>
      </div>
    </header>

    <div class="mcp-banner">
      <div class="mcp-banner-inner">
        <div class="mcp-info">
          <span class="mcp-badge">MCP Server</span>
          <p class="mcp-text">Connect this data to Claude, ChatGPT, or any MCP-compatible AI assistant</p>
        </div>
        <div class="mcp-url">
          <span class="mcp-url-label">Endpoint</span>
          <code class="mcp-url-value">https://leporello.app/mcp</code>
          <button class="mcp-copy" type="button" aria-label="Copy endpoint URL">
            <svg class="mcp-copy-icon" width="16" height="16" viewBox="0 0 16 16" fill="none"><rect x="5" y="5" width="9" height="9" rx="1.5" stroke="currentColor" stroke-width="1.3"/><path d="M3 11V3a1.5 1.5 0 011.5-1.5H11" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/></svg>
            <svg class="mcp-check-icon" width="16" height="16" viewBox="0 0 16 16" fill="none" style="display:none"><path d="M3 8.5l3.5 3.5 6.5-7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </button>
        </div>
      </div>
    </div>

    <Filters cities={cities} />

    <EventList />

    <footer class="site-footer">
      <div class="footer-inner">
        <div class="footer-grid">
          <div class="footer-section">
            <h3 class="footer-heading">Sources</h3>
            <ul class="footer-venues">
              {venueAgeList.map(({ venue, age, count }) => (
                <li class="footer-venue-row">
                  <a href={venue.url} target="_blank" rel="noopener" class="footer-venue-name">{venue.name}</a>
                  <span class="footer-venue-meta">
                    {count} {count === 1 ? 'event' : 'events'} &middot; updated {formatAge(age)}
                  </span>
                </li>
              ))}
            </ul>
          </div>
          <div class="footer-section footer-about">
            <p class="footer-note">
              Leporello aggregates publicly available concert schedules.
              All event data belongs to the respective venues.
            </p>
          </div>
        </div>
      </div>
    </footer>
  </div>

  <script>
    import '../scripts/filter.ts';

    document.querySelector('.mcp-copy')?.addEventListener('click', async (e) => {
      const btn = (e.currentTarget as HTMLElement);
      const copyIcon = btn.querySelector('.mcp-copy-icon') as HTMLElement;
      const checkIcon = btn.querySelector('.mcp-check-icon') as HTMLElement;
      await navigator.clipboard.writeText('https://leporello.app/mcp');
      copyIcon.style.display = 'none';
      checkIcon.style.display = 'block';
      setTimeout(() => {
        copyIcon.style.display = 'block';
        checkIcon.style.display = 'none';
      }, 2000);
    });
  </script>
</Base>

<style>
  .page-wrapper {
    display: flex;
    flex-direction: column;
    min-height: 100vh;
  }

  /* ── Header ── */
  .site-header {
    background: var(--bg);
  }

  .header-inner {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0.5rem 2.5rem 0.5rem;
  }

  .header-brand {
    position: relative;
    width: fit-content;
  }

  .site-logo {
    display: block;
    height: 120px;
    width: auto;
  }

  .header-text {
    position: absolute;
    left: 72px;
    top: 36px;
    white-space: nowrap;
  }

  .site-tagline {
    margin-top: 0.1rem;
  }

  .site-title {
    font-family: var(--serif);
    font-size: 2.2rem;
    font-weight: 400;
    letter-spacing: 0.02em;
    color: var(--text);
    line-height: 1;
    margin-bottom: 0.4rem;
  }

  .site-tagline {
    font-family: var(--sans);
    font-size: 0.9rem;
    font-weight: 400;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--text-muted);
  }

  /* ── MCP Banner ── */
  .mcp-banner {
    background: var(--text);
    color: var(--bg);
  }

  .mcp-banner-inner {
    max-width: 1400px;
    margin: 0 auto;
    padding: 1rem 3rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
  }

  .mcp-info {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .mcp-badge {
    font-family: var(--sans);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    background: var(--accent);
    color: #fff;
    padding: 0.3rem 0.7rem;
    border-radius: 3px;
    white-space: nowrap;
  }

  .mcp-text {
    font-family: var(--sans);
    font-size: 0.85rem;
    font-weight: 400;
    color: rgba(250, 247, 242, 0.7);
  }

  .mcp-url {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-shrink: 0;
  }

  .mcp-url-label {
    font-family: var(--sans);
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(250, 247, 242, 0.4);
  }

  .mcp-url-value {
    font-family: 'SF Mono', 'Fira Code', 'Consolas', monospace;
    font-size: 0.9rem;
    background: rgba(255, 255, 255, 0.1);
    padding: 0.35rem 0.85rem;
    border-radius: 4px;
    color: var(--bg);
    user-select: all;
    letter-spacing: 0.01em;
  }

  .mcp-copy {
    background: rgba(255, 255, 255, 0.1);
    border: 1px solid rgba(255, 255, 255, 0.15);
    border-radius: 4px;
    color: rgba(250, 247, 242, 0.6);
    cursor: pointer;
    padding: 0.35rem;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: color 0.15s, background 0.15s;
  }

  .mcp-copy:hover {
    color: #fff;
    background: rgba(255, 255, 255, 0.18);
  }

  /* ── Footer ── */
  .site-footer {
    margin-top: auto;
    background: var(--bg-warm);
    border-top: 1px solid var(--border);
  }

  .footer-inner {
    max-width: 1400px;
    margin: 0 auto;
    padding: 2.5rem 2.5rem 3rem;
  }

  .footer-grid {
    display: flex;
    gap: 4rem;
    align-items: flex-start;
  }

  .footer-section {
    flex: 1;
  }

  .footer-about {
    flex: 0 0 auto;
    max-width: 300px;
  }

  .footer-heading {
    font-family: var(--sans);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: 1rem;
  }

  .footer-venues {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .footer-venue-row {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
  }

  .footer-venue-name {
    font-family: var(--serif);
    font-size: 1.1rem;
    font-weight: 500;
    color: var(--text);
    transition: color 0.1s ease;
  }

  .footer-venue-name:hover {
    color: var(--accent);
  }

  .footer-venue-meta {
    font-family: var(--sans);
    font-size: 0.8rem;
    color: var(--text-muted);
    font-weight: 400;
  }

  .footer-note {
    font-family: var(--sans);
    font-size: 0.85rem;
    color: var(--text-muted);
    font-weight: 400;
    line-height: 1.6;
  }

  @media (max-width: 700px) {
    .header-inner {
      padding: 2rem 1.5rem 1.25rem;
    }

    .site-title {
      font-size: 2.2rem;
    }

    .footer-inner {
      padding: 2rem 1.5rem;
    }

    .mcp-banner-inner {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.75rem;
      padding: 1rem 1.5rem;
    }

    .mcp-info {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.5rem;
    }

    .mcp-url {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.3rem;
    }

    .mcp-url-value {
      font-size: 0.8rem;
    }

    .footer-grid {
      flex-direction: column;
      gap: 2rem;
    }

    .footer-about {
      max-width: none;
    }
  }
</style>
