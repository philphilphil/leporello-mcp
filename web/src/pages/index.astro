---
import Base from '../layouts/Base.astro';
import Filters from '../components/Filters.astro';
import EventList from '../components/EventList.astro';
import { getCities, getVenues, getEvents } from '../lib/data.ts';
import type { Venue } from '../lib/data.ts';

const cities = getCities();
const venues = getVenues();
const events = getEvents(90);
const dataAge: Record<string, string | null> = {};
for (const v of venues) {
  if (v.last_scraped) dataAge[v.id] = v.last_scraped;
}

const pageData = { cities, venues, events, dataAge };

function formatAge(iso: string | null): string {
  if (!iso) return 'never';
  const d = new Date(iso);
  return d.toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' });
}

const eventCountByVenue: Record<string, number> = {};
for (const e of events) {
  eventCountByVenue[e.venue_id] = (eventCountByVenue[e.venue_id] ?? 0) + 1;
}

const venueAgeList: Array<{ venue: Venue; age: string | null; count: number }> = venues.map(v => ({
  venue: v,
  age: dataAge[v.id] ?? null,
  count: eventCountByVenue[v.id] ?? 0,
}));
---

<Base title="Erda — Classical Music Events">
  <script type="application/json" id="event-data" set:html={JSON.stringify(pageData)} />

  <div class="page-wrapper">
    <header class="site-header">
      <div class="header-inner">
        <div class="header-brand">
          <h1 class="site-title">Erda</h1>
          <div class="title-rule"></div>
          <p class="site-tagline">Classical Music & Opera Events</p>
        </div>
      </div>
    </header>

    <Filters cities={cities} />

    <EventList />

    <footer class="site-footer">
      <div class="footer-inner">
        <div class="footer-grid">
          <div class="footer-section">
            <h3 class="footer-heading">Sources</h3>
            <ul class="footer-venues">
              {venueAgeList.map(({ venue, age, count }) => (
                <li class="footer-venue-row">
                  <a href={venue.url} target="_blank" rel="noopener" class="footer-venue-name">{venue.name}</a>
                  <span class="footer-venue-meta">
                    {count} {count === 1 ? 'event' : 'events'} &middot; updated {formatAge(age)}
                  </span>
                </li>
              ))}
            </ul>
          </div>
          <div class="footer-section footer-about">
            <p class="footer-note">
              Erda aggregates publicly available concert schedules.
              All event data belongs to the respective venues.
            </p>
          </div>
        </div>
      </div>
    </footer>
  </div>

  <script>import '../scripts/filter.ts';</script>
</Base>

<style>
  .page-wrapper {
    display: flex;
    flex-direction: column;
    min-height: 100vh;
  }

  /* ── Header ── */
  .site-header {
    background: var(--bg);
    padding-top: 1rem;
  }

  .header-inner {
    max-width: 960px;
    margin: 0 auto;
    padding: 2.5rem 2rem 1.75rem;
  }

  .header-brand {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0;
  }

  .site-title {
    font-family: var(--serif);
    font-size: 3.2rem;
    font-weight: 300;
    letter-spacing: 0.04em;
    color: var(--text);
    line-height: 1;
  }

  .title-rule {
    width: 2.5rem;
    height: 2px;
    background: var(--accent);
    margin: 0.7rem 0 0.6rem;
  }

  .site-tagline {
    font-family: var(--sans);
    font-size: 0.8rem;
    font-weight: 400;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-muted);
  }

  /* ── Footer ── */
  .site-footer {
    margin-top: auto;
    background: var(--bg-warm);
    border-top: 1px solid var(--border);
  }

  .footer-inner {
    max-width: 960px;
    margin: 0 auto;
    padding: 2.5rem 2rem 3rem;
  }

  .footer-grid {
    display: flex;
    gap: 4rem;
    align-items: flex-start;
  }

  .footer-section {
    flex: 1;
  }

  .footer-about {
    flex: 0 0 auto;
    max-width: 280px;
  }

  .footer-heading {
    font-family: var(--sans);
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: 1rem;
  }

  .footer-venues {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .footer-venue-row {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
  }

  .footer-venue-name {
    font-family: var(--serif);
    font-size: 1rem;
    font-weight: 500;
    color: var(--text);
    transition: color 0.12s ease;
  }

  .footer-venue-name:hover {
    color: var(--accent);
  }

  .footer-venue-meta {
    font-family: var(--sans);
    font-size: 0.75rem;
    color: var(--text-muted);
    font-weight: 400;
  }

  .footer-note {
    font-family: var(--sans);
    font-size: 0.78rem;
    color: var(--text-muted);
    font-weight: 400;
    line-height: 1.6;
  }

  /* ── Mobile ── */
  @media (max-width: 700px) {
    .header-inner {
      padding: 2rem 1.25rem 1.25rem;
    }

    .site-title {
      font-size: 2.4rem;
    }

    .footer-inner {
      padding: 2rem 1.25rem;
    }

    .footer-grid {
      flex-direction: column;
      gap: 2rem;
    }

    .footer-about {
      max-width: none;
    }
  }
</style>
